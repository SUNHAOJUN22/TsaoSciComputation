{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id", "slug", "name_en", "name_cn", "workflow", "description", "triggers",
    "inputs", "outputs", "validators", "required_evidence", "failure_modes",
    "risk_level", "human_approval_required", "implementation_level", "maturity",
    "applicability", "claim_boundary"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^TSC-[0-9]{3}$"},
    "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "name_en": {"type": "string", "minLength": 3},
    "name_cn": {"type": "string", "minLength": 2},
    "workflow": {"type": "string"},
    "description": {"type": "string", "minLength": 40},
    "triggers": {"type": "array", "minItems": 2, "items": {"type": "string"}},
    "inputs": {"type": "array", "minItems": 3, "items": {"type": "string"}},
    "outputs": {"type": "array", "minItems": 3, "items": {"type": "string"}},
    "validators": {"type": "array", "minItems": 3, "items": {"type": "string"}},
    "required_evidence": {"type": "array", "minItems": 3, "items": {"type": "string"}},
    "failure_modes": {"type": "array", "minItems": 2, "items": {"type": "string"}},
    "recommended_adapters": {"type": "array", "items": {"type": "string"}},
    "risk_level": {"enum": ["low", "medium", "high", "critical"]},
    "human_approval_required": {"type": "boolean"},
    "implementation_level": {"enum": ["native", "orchestrated", "delegated"]},
    "maturity": {"pattern": "^A[0-7]$"},
    "applicability": {"type": "string", "minLength": 20},
    "claim_boundary": {"type": "string", "minLength": 30}
  }
}
