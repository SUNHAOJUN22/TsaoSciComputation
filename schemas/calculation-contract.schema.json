{
  "$id": "https://example.org/tsao/calculation-contract.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "acceptance_criteria": {
      "type": "object"
    },
    "assumptions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "conditions": {
      "type": "object"
    },
    "question": {
      "minLength": 1,
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "system": {
      "minProperties": 1,
      "type": "object"
    },
    "target_observables": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "workflow": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "question",
    "system",
    "conditions",
    "target_observables"
  ],
  "type": "object"
}
