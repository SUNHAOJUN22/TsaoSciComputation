def join(parts:list[str], digests:list[str], label:str)->bytes:
    if len(parts)!=len(digests): raise SystemExit(f'{label} inventory mismatch')
    chunks=[]
    for name,digest in zip(parts,digests,strict=True):
        path=PAYLOAD/name
        data=path.read_bytes()
        if path.is_symlink() or hashlib.sha256(data).hexdigest()!=digest:
            raise SystemExit(f'{label} part mismatch: {name}')
        chunks.append(data)
    return b''.join(chunks)

