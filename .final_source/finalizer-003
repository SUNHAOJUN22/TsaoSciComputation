    env = dict(os.environ)
    env["SOURCE_DATE_EPOCH"] = "1700000000"
    for output in (Path("/tmp/tsao-build-a"), Path("/tmp/tsao-build-b")):
        subprocess.run(
            ["python", "scripts/package_release.py", "--output-dir", str(output)],
            cwd=source_root,
