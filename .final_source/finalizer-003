es pass.",
        replacement,
    )
    audit_path.write_text(text, encoding="utf-8")
    run("python", "scripts/build_manifest.py", cwd=source_root)
    run("python", "scripts/build_manifest.py", "--check", cwd=source_root)
    return summary


